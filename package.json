{
  "name": "talllk-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "lint:colors": "node scripts/check-color-tokens.mjs",
    "lint": "npm run lint:colors && npm run typecheck",
    "pages:build": "npx @cloudflare/next-on-pages@1",
    "pages:deploy:noop": "echo \"Skip deploy: Cloudflare Pages Git integration handles production deployment.\"",
    "postinstall": "node scripts/copy-kuromoji-dict.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.3",
    "@sentry/nextjs": "^10.60.0",
    "axios": "^1.18.1",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "next": "15.5.19",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "ajv": "8.20.0",
    "form-data": "4.0.6",
    "lodash": "4.18.1",
    "picomatch": "4.0.4",
    "postcss": "$postcss",
    "cookie": "0.7.2",
    "esbuild": "0.25.12",
    "js-yaml": "4.2.0",
    "undici": "6.27.0",
    "ws": "8.21.0"
  }
}
